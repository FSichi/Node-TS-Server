NODE_ENV=development
PORT=4000
LOG_LEVEL=info

SECRETORPRIVATEKEY=PalabraSecretaToken

# Atlas:
# DATABASE_URL=mongodb+srv://user:pass@cluster.mongodb.net/dbname?retryWrites=true&w=majority
# Local Docker:
DATABASE_URL=mongodb://admin:admin@localhost:27017/app?authSource=admin

# "*" allows all, or comma-separated allowlist:
# CORS_ORIGINS=https://app.example.com,https://admin.example.com
CORS_ORIGINS=*

BODY_LIMIT=100kb
